    <dashboard enable-sort-zone-taborder='true' name='Front_Page'>
      <style />
      <size sizing-mode='automatic' />
      <zones>
        <zone h='100000' id='4' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone forceUpdate='true' h='32889' id='5' type-v2='text' w='98882' x='559' y='37556'>
            <formatted-text>
              <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='20' italic='true'>This BDSS models how Ireland can achieve 18% forest cover through strategic species selection, soil matching, and planting rate analysis. Navigate through the story below to explore the data, trade-offs, and recommendations.</run>
              <run fontalignment='1'>Æ&#10;&#10;&#10;</run>
              <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='20' italic='true'>&quot;Climate change does not respect borders.&quot;</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='20' italic='true'>— Ban Ki-Moon</run>
            </formatted-text>
            <zone-style>
              <format attr='border-color' value='#000000' />
              <format attr='border-style' value='none' />
              <format attr='border-width' value='0' />
              <format attr='margin' value='4' />
            </zone-style>
          </zone>
          <zone forceUpdate='true' h='21333' id='6' type-v2='text' w='98882' x='559' y='70445'>
            <formatted-text>
              <run bold='true' fontname='Benton Sans Book' fontsize='14'>HOW TO USE ?</run>
              <run>Æ&#10;&#10;</run>
              <run bold='true' fontname='Benton Sans Book' fontsize='14'>1. Navigate using the story points at the top of each screen</run>
              <run>Æ&#10;</run>
              <run bold='true' fontname='Benton Sans Book' fontsize='14'>2. Use the Annual Planting Rate slider to test scenarios</run>
              <run>Æ&#10;</run>
              <run bold='true' fontname='Benton Sans Book' fontsize='14'>3. Filter by soil texture on the Map dashboard</run>
              <run>Æ&#10;</run>
              <run bold='true' fontname='Benton Sans Book' fontsize='14'>4. Hover over any chart for detailed tooltips</run>
              <run>Æ&#10;</run>
              <run bold='true' fontname='Benton Sans Book' fontsize='14'>5. The Deep Dive dashboard provides supporting metrics</run>
            </formatted-text>
            <zone-style>
              <format attr='border-color' value='#000000' />
              <format attr='border-style' value='none' />
              <format attr='border-width' value='0' />
              <format attr='margin' value='4' />
            </zone-style>
          </zone>
          <zone forceUpdate='true' h='7333' id='7' type-v2='text' w='98882' x='559' y='91778'>
            <formatted-text>
              <run fontcolor='#000000' fontname='Benton Sans Book'>Built with Tableau Public | Data: UK Forest Research Carbon Calculator V3.0 (Aug 2025) | Irish Soil Information System GIS</run>
            </formatted-text>
            <zone-style>
              <format attr='border-color' value='#000000' />
              <format attr='border-style' value='none' />
              <format attr='border-width' value='0' />
              <format attr='margin' value='4' />
            </zone-style>
          </zone>
          <zone h='36667' id='12' param='D:/1-Masters/Spring/BDSS/assignment 2/MIS41040_team22_tableau.twb Files/Image/Mountains Firewatch Wallpaper.jpg' type-v2='bitmap' w='98882' x='559' y='889'>
            <zone-style>
              <format attr='border-color' value='#000000' />
              <format attr='border-style' value='none' />
              <format attr='border-width' value='0' />
              <format attr='margin' value='4' />
            </zone-style>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone h='2667' id='9' type-v2='dashboard-object' w='1676' x='0' y='0'>
          <button action=''>
            <toggle-action>tabdoc:toggle-button-click-action window-id=&quot;{F272B0D5-C049-47A8-9345-1A1BAB44980F}&quot; zone-id=&quot;9&quot; zone-ids=[4]</toggle-action>
            <button-visual-state />
