    <dashboard enable-sort-zone-taborder='true' name='Carbon_Dashboard'>
      <style />
      <size sizing-mode='automatic' />
      <zones>
        <zone h='100000' id='4' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98222' id='7' param='horz' type-v2='layout-flow' w='98882' x='559' y='889'>
            <zone h='98222' id='5' type-v2='layout-basic' w='87709' x='559' y='889'>
              <zone h='37056' id='3' name='Carbon Performance' w='43855' x='559' y='25000'>
                <zone-style>
                  <format attr='border-color' value='#000000' />
                  <format attr='border-style' value='none' />
                  <format attr='border-width' value='0' />
                  <format attr='margin' value='4' />
                </zone-style>
              </zone>
              <zone forceUpdate='true' h='24111' id='9' type-v2='text' w='87709' x='559' y='889'>
                <formatted-text>
                  <run bold='true' fontalignment='1' fontcolor='#555555' fontname='Benton Sans Book' fontsize='20' italic='true'>WHY THESE 5 SPECIES?</run>
                  <run fontalignment='1'>Æ&#10;&#10;</run>
                  <run bold='true' fontalignment='1' fontcolor='#555555' fontname='Benton Sans Book' fontsize='8' italic='true'>From 135 catalogued species mapped to 19 unique carbon-growth models in the Forest Research Carbon Calculator V3.0, I selected:</run>
                  <run fontalignment='1'>Æ&#10;&#10;</run>
                  <run bold='true' fontalignment='1' fontcolor='#555555' fontname='Benton Sans Book' fontsize='8' italic='true'>-</run>
                  <run bold='true' fontalignment='1' fontcolor='#555555' fontname='Benton Sans Book' fontsize='12' italic='true'> Sitka Spruce — dominant Irish commercial conifer, thrives on peat</run>
                  <run fontalignment='1'>Æ&#10;</run>
                  <run bold='true' fontalignment='1' fontcolor='#555555' fontname='Benton Sans Book' fontsize='12' italic='true'>- Western Hemlock — highest long-term sequestration, late-succession</run>
                  <run fontalignment='1'>Æ&#10;</run>
                  <run bold='true' fontalignment='1' fontcolor='#555555' fontname='Benton Sans Book' fontsize='12' italic='true'>- Douglas Fir — deep-rooted, high timber value on mineral soils</run>
                  <run fontalignment='1'>Æ&#10;</run>
                  <run bold='true' fontalignment='1' fontcolor='#555555' fontname='Benton Sans Book' fontsize='12' italic='true'>- Grand Fir — shade-tolerant, ideal for mixed stands</run>
                  <run fontalignment='1'>Æ&#10;</run>
                  <run bold='true' fontalignment='1' fontcolor='#555555' fontname='Benton Sans Book' fontsize='12' italic='true'>- Beech — broadleaf representation for biodiversity</run>
                  <run fontalignment='1'>Æ&#10;&#10;</run>
                  <run bold='true' fontalignment='1' fontcolor='#555555' fontname='Benton Sans Book' fontsize='8' italic='true'>Selection criteria: (1) Irish climatic suitability, (2) functional diversity, (3) top-decile sequestration rank, (4) alignment with actual Afforestation Scheme plantings.</run>
                </formatted-text>
                <zone-style>
                  <format attr='border-color' value='#000000' />
                  <format attr='border-style' value='none' />
                  <format attr='border-width' value='0' />
                  <format attr='margin' value='4' />
                </zone-style>
              </zone>
              <zone h='74111' id='10' name='Total (tC02e/ha/yr)' w='43854' x='44414' y='25000'>
