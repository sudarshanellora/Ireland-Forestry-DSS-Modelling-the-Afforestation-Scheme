                <story-points>
                  <story-point caption='Introduction ' captured-sheet='Front_Page' id='10' />
                  <story-point caption='The Challenge: Ireland must grow forest cover from 11.6% to 18% by 2027' captured-sheet='Target_Tracking_Dashboard' id='1' />
                  <story-point caption='At 8,000 ha/year, the 18% target is not reached until ~2077 — 50 years late&#9;' captured-sheet='Projected' id='2' />
                  <story-point caption='From 135 catalogued species and 19 model types, we selected 5 that span climatic suitability, functional diversity, sequestration rank, and real-world Irish planting patterns' captured-sheet='Carbon_Dashboard' id='8' />
                  <story-point caption='Western Hemlock leads long-term sequestration; Sitka Spruce grows fastest early&#9;' captured-sheet='Carbon Over Time' id='3' />
                  <story-point caption='Beyond the headline: debris, rate, and harvest reveal the real-world trade-offs between species' captured-sheet='Deep_Dive_Extras' id='7' />
                  <story-point caption='No-thinning nearly doubles cumulative CO₂ capture — but reduces timber value&#9;' captured-sheet='Thining Comparision ' id='4' />
                  <story-point caption='TREE × SOIL SUITABILITY MATRIX&#10;&#9;' captured-sheet='Dashboard 8' id='11' />
