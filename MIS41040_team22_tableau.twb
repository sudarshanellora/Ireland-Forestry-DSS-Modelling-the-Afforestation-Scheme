      <column caption='Biodiversity Score' datatype='integer' name='[Calculation_0923716065128448]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF CONTAINS([Species name], &quot;Oak&quot;) THEN 5&#10;ELSEIF CONTAINS([Species name], &quot;Birch&quot;) THEN 5&#10;ELSEIF CONTAINS([Species name], &quot;Beech&quot;) THEN 4&#10;ELSEIF CONTAINS([Species name], &quot;Scots pine&quot;) THEN 3&#10;ELSEIF CONTAINS([Species name], &quot;Sitka spruce&quot;) THEN 2&#10;ELSE 3&#10;END' />
      </column>
      <column caption='Rank' datatype='integer' name='[Calculation_0923716067135490]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(AVG([Carbon standing (tCO2e/ha/yr)]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Tree Name' datatype='string' name='[Calculation_0923717165092881]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Species] = &quot;BE&quot; THEN &quot;Beech&quot;&#10;ELSEIF [Species] = &quot;SS&quot; THEN &quot;Sitka Spruce&quot;&#10;ELSEIF [Species] = &quot;GF&quot; THEN &quot;Grand Fir&quot;&#10;ELSEIF [Species] = &quot;DF&quot; THEN &quot;Douglas Fir&quot;&#10;ELSEIF [Species] = &quot;WH&quot; THEN &quot;Western Hemlock&quot;&#10;END' />
      </column>
      <column caption='Farmer Total (€)' datatype='real' name='[Calculation_0923717167427602]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Parameters].[Parameter 1] * [Parameters].[Parameter 2] * 20' />
      </column>
      <column caption='Non-Farmer Total (€)' datatype='real' name='[Calculation_0923717167513619]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Parameters].[Parameter 1] * [Parameters].[Parameter 2] * 15' />
      </column>
      <column caption='Target Forest Cover %' datatype='real' name='[Calculation_0923717459746840]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Parameters].[Parameter 5] / 100 * [Parameters].[Parameter 6]' />
      </column>
      <column caption='Years to Target' datatype='real' name='[Calculation_0923717459918875]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0923717489102878] / [Parameters].[Parameter 3]' />
      </column>
      <column caption='Current Forest Area (ha)' datatype='real' name='[Calculation_0923717487996957]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Parameters].[Parameter 4]/ 100 * [Parameters].[Parameter 6]' />
      </column>
      <column caption='Hectares Gap to Target' datatype='real' name='[Calculation_0923717489102878]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0923717489709087] - [Calculation_0923717487996957]' />
      </column>
      <column caption='Target Forest Area (ha)' datatype='real' name='[Calculation_0923717489709087]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0923717459746840] / 100 * [Parameters].[Parameter 6]' />
      </column>
      <column caption='Years to Reach Target' datatype='real' name='[Calculation_0923717489967137]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0923717489102878] / [Parameters].[Parameter 3]' />
      </column>
      <column caption='Target Year' datatype='real' name='[Calculation_0923717490012194]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='2026 + [Calculation_0923717489967137]' />
      </column>
      <column caption='Progress to Target %' datatype='real' name='[Calculation_0923717490114595]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Parameters].[Parameter 4] / [Calculation_0923717459746840]) * 100' />
      </column>
      <column caption='Current Cover Display' datatype='real' name='[Calculation_0923717490855972]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Parameters].[Parameter 4]' />
      </column>
