      <column caption='Best Tree Species ' datatype='string' name='[Calculation_0923717146738695]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [TEXTURE] = &quot;Peat&quot; OR [DRAINAGE] = &quot;Poor&quot;&#10;THEN &quot;Sitka Spruce&quot;&#10;ELSEIF [TEXTURE] = &quot;Loamy&quot; AND [DRAINAGE] = &quot;Well&quot;&#10;THEN &quot;Grand Fir&quot;&#10;ELSEIF [TEXTURE] = &quot;Sandy&quot; OR [DRAINAGE] = &quot;Excessively&quot;&#10;THEN &quot;Douglas Fir&quot;&#10;ELSEIF [DRAINAGE] = &quot;moderately&quot; OR [TEXTURE] = &quot;Fine loamy&quot;&#10;THEN &quot;Western Hemlock&quot;&#10;ELSE &quot;Beech&quot;&#10;END' />
      </column>
      <column caption='Payment Years' datatype='integer' name='[Calculation_0923717163638795]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 3] = &quot;Farmer&quot; &#10;THEN 20 &#10;ELSE 15 &#10;END' />
      </column>
      <column caption='Annual Premium (€)' datatype='real' name='[Calculation_0923717163720716]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Parameters].[Parameter 1] * [Parameters].[Parameter 2]' />
      </column>
      <column caption='Suitability Score' datatype='integer' name='[Calculation_0923717839933483]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_0923717146738695] = &quot;Sitka Spruce&quot; AND [TEXTURE] = &quot;Peat&quot; THEN 5&#10;ELSEIF [Calculation_0923717146738695] = &quot;Sitka Spruce&quot; AND [TEXTURE] = &quot;Loamy&quot; THEN 4&#10;ELSEIF [Calculation_0923717146738695] = &quot;Sitka Spruce&quot; AND [TEXTURE] = &quot;Clayey&quot; THEN 3&#10;ELSEIF [Calculation_0923717146738695] = &quot;Sitka Spruce&quot; AND [TEXTURE] = &quot;Sandy&quot; THEN 2&#10;ELSEIF [Calculation_0923717146738695] = &quot;Sitka Spruce&quot; AND [TEXTURE] = &quot;Fine loamy&quot; THEN 3&#10;ELSEIF [Calculation_0923717146738695] = &quot;Sitka Spruce&quot; AND [TEXTURE] = &quot;Coarse loamy&quot; THEN 3&#10;&#10;&#10;ELSEIF [Calculation_0923717146738695] = &quot;Beech&quot; AND [TEXTURE] = &quot;Loamy&quot; THEN 5&#10;ELSEIF [Calculation_0923717146738695] = &quot;Beech&quot; AND [TEXTURE] = &quot;Fine loamy&quot; THEN 5&#10;ELSEIF [Calculation_0923717146738695] = &quot;Beech&quot; AND [TEXTURE] = &quot;Clayey&quot; THEN 4&#10;ELSEIF [Calculation_0923717146738695] = &quot;Beech&quot; AND [TEXTURE] = &quot;Coarse loamy&quot; THEN 3&#10;ELSEIF [Calculation_0923717146738695] = &quot;Beech&quot; AND [TEXTURE] = &quot;Peat&quot; THEN 1&#10;&#10;ELSEIF [Calculation_0923717146738695] = &quot;Douglas Fir&quot; AND [TEXTURE] = &quot;Fine loamy&quot; THEN 5&#10;ELSEIF [Calculation_0923717146738695] = &quot;Douglas Fir&quot; AND [TEXTURE] = &quot;Loamy&quot; THEN 4&#10;ELSEIF [Calculation_0923717146738695] = &quot;Douglas Fir&quot; AND [TEXTURE] = &quot;Coarse loamy&quot; THEN 4&#10;ELSEIF [Calculation_0923717146738695] = &quot;Douglas Fir&quot; AND [TEXTURE] = &quot;Clayey&quot; THEN 2&#10;ELSEIF [Calculation_0923717146738695] = &quot;Douglas Fir&quot; AND [TEXTURE] = &quot;Peat&quot; THEN 2&#10;ELSEIF [Calculation_0923717146738695] = &quot;Douglas Fir&quot; AND [TEXTURE] = &quot;Sandy&quot; THEN 2&#10;&#10;ELSEIF [Calculation_0923717146738695] = &quot;Grand Fir&quot; AND [TEXTURE] = &quot;Fine loamy&quot; THEN 5&#10;ELSEIF [Calculation_0923717146738695] = &quot;Grand Fir&quot; AND [TEXTURE] = &quot;Loamy&quot; THEN 4&#10;ELSEIF [Calculation_0923717146738695] = &quot;Grand Fir&quot; AND [TEXTURE] = &quot;Coarse loamy&quot; THEN 3&#10;ELSEIF [Calculation_0923717146738695] = &quot;Grand Fir&quot; AND [TEXTURE] = &quot;Clayey&quot; THEN 3&#10;ELSEIF [Calculation_0923717146738695] = &quot;Grand Fir&quot; AND [TEXTURE] = &quot;Peat&quot; THEN 2&#10;&#10;ELSEIF [Calculation_0923717146738695] = &quot;Western Hemlock&quot; AND [TEXTURE] = &quot;Loamy&quot; THEN 5&#10;ELSEIF [Calculation_0923717146738695] = &quot;Western Hemlock&quot; AND [TEXTURE] = &quot;Fine loamy&quot; THEN 4&#10;ELSEIF [Calculation_0923717146738695] = &quot;Western Hemlock&quot; AND [TEXTURE] = &quot;Coarse loamy&quot; THEN 4&#10;ELSEIF [Calculation_0923717146738695] = &quot;Western Hemlock&quot; AND [TEXTURE] = &quot;Clayey&quot; THEN 3&#10;ELSEIF [Calculation_0923717146738695] = &quot;Western Hemlock&quot; AND [TEXTURE] = &quot;Peat&quot; THEN 2&#10;&#10;ELSE 0&#10;END' />
