    <worksheet name='Sheet 15'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Biodiversity is the hidden trade-off: Sitka Spruce wins on CO₂ but scores lowest on biodiversity</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Biomass carbon lookup table (Tableau Assignenment)' name='federated.0ax8r50127502x187fxlm18mgzyt' />
          </datasources>
          <datasource-dependencies datasource='federated.0ax8r50127502x187fxlm18mgzyt'>
            <column caption='Biodiversity Score' datatype='integer' name='[Calculation_0923716065128448]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF CONTAINS([Species name], &quot;Oak&quot;) THEN 5&#10;ELSEIF CONTAINS([Species name], &quot;Birch&quot;) THEN 5&#10;ELSEIF CONTAINS([Species name], &quot;Beech&quot;) THEN 4&#10;ELSEIF CONTAINS([Species name], &quot;Scots pine&quot;) THEN 3&#10;ELSEIF CONTAINS([Species name], &quot;Sitka spruce&quot;) THEN 2&#10;ELSE 3&#10;END' />
            </column>
            <column caption='Tree Name' datatype='string' name='[Calculation_0923717165092881]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Species] = &quot;BE&quot; THEN &quot;Beech&quot;&#10;ELSEIF [Species] = &quot;SS&quot; THEN &quot;Sitka Spruce&quot;&#10;ELSEIF [Species] = &quot;GF&quot; THEN &quot;Grand Fir&quot;&#10;ELSEIF [Species] = &quot;DF&quot; THEN &quot;Douglas Fir&quot;&#10;ELSEIF [Species] = &quot;WH&quot; THEN &quot;Western Hemlock&quot;&#10;END' />
            </column>
            <column datatype='string' name='[Species name]' role='dimension' type='nominal' />
            <column datatype='string' name='[Species]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_0923716065128448]' derivation='Avg' name='[avg:Calculation_0923716065128448:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0923717165092881]' derivation='None' name='[none:Calculation_0923717165092881:nk]' pivot='key' type='nominal' />
            <column-instance column='[Species name]' derivation='None' name='[none:Species name:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0923716065128448]' derivation='Sum' name='[sum:Calculation_0923716065128448:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0ax8r50127502x187fxlm18mgzyt].[none:Calculation_0923717165092881:nk]'>
            <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
              <groupfilter function='member' level='[none:Calculation_0923717165092881:nk]' member='&quot;Beech&quot;' />
              <groupfilter function='member' level='[none:Calculation_0923717165092881:nk]' member='&quot;Douglas Fir&quot;' />
              <groupfilter function='member' level='[none:Calculation_0923717165092881:nk]' member='&quot;Grand Fir&quot;' />
